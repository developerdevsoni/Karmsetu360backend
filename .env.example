# Server Config
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/karmsetu?schema=public"

# JWT Config
JWT_ACCESS_SECRET="super_secret_access_token_key"
JWT_REFRESH_SECRET="super_secret_refresh_token_key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"


# SMTP (Email) Config
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Karmsetu HR <noreply@karmsetu.com>"

# Firebase Cloud Messaging (FCM) Config
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""

# Initial Bootstrapping (Seed)
SUPERADMIN_EMAIL="superadmin@karmsetu.com"
SUPERADMIN_PASSWORD="SuperSecureAdmin123!"
